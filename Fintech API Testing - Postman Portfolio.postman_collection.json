          "name": "Transactions (User Carts)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "const transactions = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Transactions array is returned\", function () {\r",
                  "    pm.expect(transactions).to.be.an(\"array\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Each transaction belongs to user 1\", function () {\r",
                  "    transactions.forEach(tx => {\r",
                  "        pm.expect(tx.userId).to.eql(1);\r",
                  "    });\r",
                  "});\r",
                  ""
                ],
